# --- Rabbit-Technik Server ---
# Als Datei "server/.env" speichern ODER als ".env" im Projektroot (Monorepo).
# Wird beim Start automatisch geladen (unabhängig vom Arbeitsverzeichnis).

# =============================================================================
# Persistente Daten (Railway / Docker: sonst gehen DB & Dateien bei jedem Deploy verloren)
# =============================================================================
#
# Volume z. B. auf /data mounten. Liegt dort: rabbit.db, uploads/, invoices/, acceptance/, backups/
#
RABBIT_DATA_DIR=/data
#
# Lokal ohne Docker-/data-Volume: Zeile auskommentieren oder z. B. RABBIT_DATA_DIR=./server/data
#
# Ohne diese Zeile auf Railway: wenn /data gemountet und beschreibbar ist, nutzt die App /data automatisch.

# --- Datensicherung / Snapshots (geschäftsrelevant: SQLite = Kunden, Aufträge, Rechnungen, Zahlungen, Abschlüsse, Berichte) ---
# Automatisch aktiv, wenn RAILWAY_* gesetzt ist oder RABBIT_DATA_DIR / RABBIT_DB_PATH gesetzt.
# RABBIT_BACKUP_ENABLED=0   # Snapshots abschalten
# RABBIT_BACKUP_ENABLED=1   # Snapshots erzwingen (z. B. lokal mit RABBIT_DATA_DIR)
# RABBIT_BACKUP_INTERVAL_HOURS=24
# RABBIT_BACKUP_KEEP=14     # Anzahl aufzubewahrender Snapshot-Ordner unter …/backups/
#
# Manuell (Werkstatt-Login): POST /api/system/backup
#
# Optional nur die SQLite-Datei woanders (Uploads/PDFs bleiben dann unter server/data, sofern nicht auch umgestellt):
# RABBIT_DB_PATH=/data/rabbit.db

# Optional: Prozess-Zeitzone (PDF/E-Mail formatieren zusätzlich explizit Europe/Berlin im Code).
# TZ=Europe/Berlin

# Öffentliche Basis-URL für Tracking (E-Mails, QR ohne Request-Kontext). Ohne trailing slash.
# Pflicht sinnvoll, sobald E-Mails mit Tracking-Link rausgehen – sonst steht dort localhost.
# Alternativen (erste gesetzte gewinnt): RABBIT_PUBLIC_SITE_URL, RAILWAY_STATIC_URL, RAILWAY_PUBLIC_DOMAIN (Railway).
# QR-Bild im Browser: wenn diese Variablen leer sind, wird die Domain aus der aktuellen Anfrage genutzt.
PUBLIC_TRACKING_URL=https://deine-domain.de
# RABBIT_PUBLIC_SITE_URL=https://deine-domain.de

# Optional: Werkstatt-Passwort (Tablet / API-Schutz)
# RABBIT_WORKSHOP_PASSWORD=

# =============================================================================
# SumUp (Kartenzahlung am Abholen – Checkout-Link / QR in der Werkstatt)
# =============================================================================
# API-Key aus SumUp Dashboard (Developer → API keys). Merchant-Code: Profil / Konto.
# Ohne diese Variablen liefert POST /api/repairs/:id/pickup mit action sumup_link einen Hinweis (503).
# RABBIT_SUMUP_API_KEY=
# RABBIT_SUMUP_MERCHANT_CODE=
# Optional: volle Webhook-URL (POST). Standard: PUBLIC_TRACKING_URL oder RABBIT_PUBLIC_SITE_URL + /webhook/sumup
# SumUp sendet CHECKOUT_STATUS_CHANGED an die bei Online-Checkout gesetzte return_url.
# RABBIT_SUMUP_WEBHOOK_URL=https://deine-api-domain.de/webhook/sumup
#
# Tap to Pay (Handyzahlung) wird in der Werkstatt manuell abgeschlossen (keine SumUp-App-/SDK-Anbindung in dieser App).

# =============================================================================
# E-Mail Versand
# =============================================================================
#
# --- Railway Hobby/Free: ausgehendes SMTP ist gesperrt → „Connection timeout“ zu Gmail.
#     Nutze Resend (HTTPS, kostenlos starten): https://resend.com → API-Key:
# RABBIT_RESEND_API_KEY=re_xxxxxxxx
# Absender bei Resend: KEIN @gmail.com (nicht verifizierbar). Eigenen Domain unter resend.com/domains
# anlegen oder Test-Absender:
# RABBIT_RESEND_FROM=Rabbit-Technik <onboarding@resend.dev>
# Ohne RABBIT_RESEND_FROM nutzt die App automatisch onboarding@resend.dev.
#
# --- SMTP (lokal oder Railway Pro): Gmail mit App-Passwort
#
# 1) Google-Konto: https://myaccount.google.com/security
# 2) 2-Faktor-Authentifizierung aktivieren (Pflicht für App-Passwörter)
# 3) App-Passwort erstellen: Sicherheit → App-Passwörter → „Mail“ / „Sonstiges“
#    → 16-stelliges Passwort kopieren (ohne Leerzeichen) nach RABBIT_SMTP_PASS
#
# Preset „gmail“ setzt den Host automatisch auf smtp.gmail.com (RABBIT_SMTP_HOST optional)
RABBIT_SMTP_PRESET=gmail

RABBIT_SMTP_USER=rabbit.technik@gmail.com
RABBIT_SMTP_PASS=hier-16-stelliges-app-passwort

# Absender (sollte dieselbe Adresse sein wie das Gmail-Konto)
RABBIT_SMTP_FROM=Rabbit-Technik <rabbit.technik@gmail.com>

# Ohne RABBIT_SMTP_PORT: für Gmail wird 465 (SSL) verwendet – oft stabiler in der Cloud (Railway) als 587.
# Bei Timeout: nichts setzen (=465) oder explizit RABBIT_SMTP_PORT=465
# Alternativ STARTTLS testen: RABBIT_SMTP_PORT=587
#
# RABBIT_SMTP_IPV4=0   # IPv4-Zwang abschalten (Standard: an, weniger Timeouts in Containern)
# RABBIT_SMTP_DEBUG=1  # SMTP-Debug-Log in der Server-Konsole

# Empfänger für automatische Tages-/Monatsberichte per E-Mail (nach neuer Abschlusszeile in der DB).
# Standard: rabbit.technik@gmail.com (wie im Code unter COMPANY.email)
# RABBIT_REPORT_EMAIL_TO=rabbit.technik@gmail.com

# Beliebiger anderer Anbieter: PRESET leer lassen und Host setzen
# RABBIT_SMTP_PRESET=
# RABBIT_SMTP_HOST=smtp.beispiel.de

# =============================================================================
# DATEV-Export (Buchungsstapel CSV)
# =============================================================================
# Konten konfigurierbar (Standard: SKR03). Export rein lesend, keine DB-Änderung.
# RABBIT_DATEV_ERLOES_KONTO=8400        # Erlöse (SKR03: 8400, SKR04: 4400)
# RABBIT_DATEV_KASSE_KONTO=1000         # Kasse
# RABBIT_DATEV_BANK_KONTO=1200          # Bank
# RABBIT_DATEV_GELDTRANSIT_KONTO=1360   # Geldtransit (SumUp)
# RABBIT_DATEV_BERATER_NR=0             # Beraternummer vom Steuerberater
# RABBIT_DATEV_MANDANTEN_NR=1           # Mandantennummer
# RABBIT_DATEV_WJ_BEGINN=01             # Wirtschaftsjahr-Beginn (Monat, 01 = Januar)
#
# Endpunkte:
#   GET /api/erp/datev/preview?from=YYYY-MM-DD&to=YYYY-MM-DD   → Vorschau (JSON)
#   GET /api/erp/datev/export.csv?from=YYYY-MM-DD&to=YYYY-MM-DD → CSV-Download
